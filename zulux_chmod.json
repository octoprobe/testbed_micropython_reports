    {
        "directory_self": {
            "chmod": "www-data:www-data:rwxr-x---"
        }
    },
    {
        "files": {
            "patterns": [
                "!.venv/*",
                "*"
            ],
            "chmod": "www-data:www-data:"
        },
        "directories": {
            "patterns": [
                "!.venv/",
                "!.venv/*/",
                "*/"
            ],
            "chmod": "www-data:www-data:rwxr-x---"
        }
    }
