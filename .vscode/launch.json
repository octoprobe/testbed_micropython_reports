{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "DIRECTORY_REPORTS": "${workspaceFolder}/reports",
                "WEBHOOK_SECRET": "1243",
            },
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": false,
            "jinja": true
        },
        {
            "name": "parse_logfile.py",
            "type": "debugpy",
            "request": "launch",
            "module": "app.parse_logfile",
            "args": [],
            "cwd": "${workspaceFolder}",
            "jinja": true
        },
        {
            "name": "pytest",
            "type": "debugpy",
            "request": "launch",
            "purpose": [
                "debug-test"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "subProcess": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder:testbed_micropython_reports}"
            }
        }
    ]
}