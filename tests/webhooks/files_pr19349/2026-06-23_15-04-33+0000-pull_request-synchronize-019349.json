            "html_url": "https://github.com/robert-hh",
            "followers_url": "https://api.github.com/users/robert-hh/followers",
            "following_url": "https://api.github.com/users/robert-hh/following{/other_user}",
            "gists_url": "https://api.github.com/users/robert-hh/gists{/gist_id}",
            "starred_url": "https://api.github.com/users/robert-hh/starred{/owner}{/repo}",
            "subscriptions_url": "https://api.github.com/users/robert-hh/subscriptions",
            "organizations_url": "https://api.github.com/users/robert-hh/orgs",
